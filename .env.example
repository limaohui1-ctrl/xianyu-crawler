# ACS 资料采集助手 — 环境配置模板
#
# 使用方法：
#   1. 复制为 .env：  copy .env.example .env
#   2. 如需修改，编辑 .env 即可
#
# .env 不会被提交到 Git，仅保存在本机。

# ── 安全模式（不可修改为 on）──
# shadow：测试模式，所有采集在 shadow 下运行，不会有真实副作用
# on：    生产模式（当前版本未启用/不支持）
ACS_MODE=shadow

# ── 搜索 Provider ──
# 当前仅支持 searxng（本地自托管元搜索引擎）
ACS_SEARCH_PROVIDER=searxng

# ── SearXNG 本地搜索配置 ──
# 本地 SearXNG 地址（默认本机 8080 端口，如部署在其他机器请修改 IP）
ACS_SEARXNG_BASE_URL=http://127.0.0.1:8080

# 请求超时（秒），网络慢可调大
ACS_SEARXNG_TIMEOUT=15

# 每日最多搜索次数（超出后当日不再搜索）
ACS_SEARXNG_DAILY_LIMIT=200

# 每个主题最多翻页数
ACS_SEARXNG_PAGE_LIMIT=2

# 每次查询最多返回结果数
ACS_SEARXNG_RESULTS_PER_QUERY=10

# 安全搜索等级：0=关闭，1=中等，2=严格
ACS_SEARXNG_SAFESEARCH=1

# 搜索语言
ACS_SEARXNG_LANGUAGE=zh-CN

# 搜索分类（多个用英文逗号分隔）
ACS_SEARXNG_CATEGORIES=general

# ── AI 服务（可选，用于 AI 辅助功能）──
# 如不需要 AI 辅助，可保持注释状态
# AI_PROVIDER=deepseek
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_API_KEY=你的API密钥
# AI_MODEL=deepseek-chat

# ── 通用配置 ──
# 数据目录（默认 acs_data/）
# ACS_DATA_DIR=acs_data
# 日志级别：DEBUG / INFO / WARNING / ERROR
# ACS_LOG_LEVEL=INFO
